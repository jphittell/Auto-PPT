{
  "$schema_doc": "Chart Spec Catalog — Auto PPT v1",
  "$description": "Canonical collection of chart payloads for the asset stage. Each entry is a complete chart_spec dict that can be passed directly to render_chart_to_png() (supported specs) or used as a contract target for renderer expansion (planned specs). See $field_reference for the full intended schema.",

  "$field_reference": {
    "chart_type":              "string — one of the values listed in $supported_chart_types or $planned_chart_types",
    "title":                   "string — slide-level chart title rendered above the plot",
    "x_label":                 "string | null — axis label for the x-axis (omit for pie/donut/kpi_tile)",
    "y_label":                 "string | null — axis label for the y-axis (omit for pie/donut/kpi_tile)",
    "accent_color":            "hex string — primary series color; default #0A84FF",
    "palette":                 "list[hex] — ordered color list for multi-series or segmented charts",
    "data":                    "list[{label, value}] — flat data shape consumed by current renderer for single-series charts",
    "series":                  "list[{name, data: list[{label, value}]}] — multi-series shape for stacked/grouped/multi-line/combo charts",
    "categories":              "list[string] — explicit x-axis category order; inferred from data[].label when absent",
    "show_data_labels":        "bool — render value labels directly on bars/points/segments",
    "show_legend":             "bool — render a legend; always false for single-series charts",
    "aspect_ratio":            "float — target width/height for the output PNG; used by asset resolver for slot fit/fill",
    "intended_template_keys":  "list[string] — template registry keys this chart is designed to fill",
    "renderer_status":         "supported | planned — whether chart_renderer.py currently handles this chart_type"
  },

  "$supported_chart_types":  ["bar", "line", "pie", "scatter"],
  "$planned_chart_types":    ["stacked_bar", "grouped_bar", "area", "multi_line", "donut", "waterfall", "horizontal_bar", "kpi_tile", "combo_bar_line"],

